# Supabase 项目配置(在 Supabase 控制台 -> Project Settings -> API 获取)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 仅导入脚本使用的 service_role key(切勿暴露到前端 / 切勿提交到 git)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- 注册通知(可选,推送到微信)----
# Server酱 SendKey(https://sct.ftqq.com 扫码登录后获取,SCT 开头)
SERVERCHAN_SENDKEY=your-serverchan-sendkey
# 自定义的一串随机字符串,用于保护 /api/notify 接口(自己随便编一串长字符)
NOTIFY_SECRET=your-random-secret-string
